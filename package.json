
{
  "name": "corpus",
  "version": "1.0.0",
  "description": "Corpus builder and particle measurement GUI for TEM nanoparticle datasets",
  "homepage": "https://github.com/local/corpus",
  "main": "main.js",  
  "build": {
    "productName": "Corpus",
    "appId": "org.corpus.tem",
    "asar": false,
    "files": [
      "**/*",
      "!data/**",
      "!reports/**",
      "!runs/**",
      "!dist/**",
      "!**/__pycache__/**",
      "!**/*.pyc"
    ],
    "linux": {
      "category": "Science",
      "maintainer": "Corpus Maintainers <corpus@localhost>",
      "target": [
        "AppImage",
        "dir"
      ]
    },
    "mac": {
      "target": [
        "dmg",
        "zip"
      ]
    },
    "win": {
      "target": [
        "nsis",
        "zip"
      ]
    }
  },
  "repository": {
    "type": "git",
    "url": ""
  },
  "scripts": {
    "start": "electron .",
    "dist": "electron-builder",
    "dist:linux": "electron-builder --linux dir --x64",
    "dist:linux:deb": "electron-builder --linux deb --x64",
    "package:ubuntu": "npm run dist:linux && tar -czf dist/Corpus-1.0.0-linux-x64.tar.gz -C dist linux-unpacked",
    "package:ubuntu:appimage": "electron-builder --linux AppImage --x64"
  },
  "devDependencies": {
    "electron": "^26.1.0",
    "electron-builder": "^24.13.3"
  },
  "dependencies": {
    "@electron/remote": "^2.0.11",
    "chart.js": "^4.4.0",
    "echarts": "^5.4.3"
  },
  "author": {
    "name": "Tesla_SHT",
    "email": "corpus@localhost"
  },
  "license": "ISC"
}

